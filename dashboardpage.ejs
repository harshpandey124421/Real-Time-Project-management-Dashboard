<%- include('headerpart') %>

<div class="pagetop">
  <div>
    <div class="pagetop-title">Dashboard</div>
    <div class="pagetop-sub">What would you like to do today?</div>
  </div>
</div>

<!-- welcome card -->
<div class="welcome-card">
  <div class="welcome-avatar"><%= loggedUser.myname[0].toUpperCase() %></div>
  <div>
    <div class="welcome-name">Hello, <%= loggedUser.myname %> 👋</div>
    <div class="welcome-info">@<%= loggedUser.username %> &nbsp;·&nbsp; <%= loggedUser.myemail %></div>
  </div>
</div>

<!-- menu cards -->
<div class="menurow">
  <a href="#" class="menucard">
    <div class="menucard-icon">📁</div>
    <div class="menucard-title">My Projects</div>
    <div class="menucard-desc">View and manage all your projects</div>
  </a>
  <a href="#" class="menucard">
    <div class="menucard-icon">➕</div>
    <div class="menucard-title">New Project</div>
    <div class="menucard-desc">Start a brand new project</div>
  </a>
  <a href="#" class="menucard">
    <div class="menucard-icon">✅</div>
    <div class="menucard-title">My Tasks</div>
    <div class="menucard-desc">See tasks assigned to you</div>
  </a>
  <a href="#" class="menucard">
    <div class="menucard-icon">👥</div>
    <div class="menucard-title">Collaborators</div>
    <div class="menucard-desc">Manage your team members</div>
  </a>
</div>

<%- include('footerpart') %>
